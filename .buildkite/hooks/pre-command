#!/usr/bin/env bash
# pre-command hook: runs before each command step in Buildkite
# Sets up the environment, configures credentials, and prepares build tooling.

set -euo pipefail

echo '--- :buildkite: Setting up build environment'

# Ensure required environment variables are present
REQUIRED_VARS=(
  "BUILDKITE_BRANCH"
  "BUILDKITE_BUILD_NUMBER"
  "BUILDKITE_PIPELINE_SLUG"
)

for var in "${REQUIRED_VARS[@]}"; do
  if [[ -z "${!var:-}" ]]; then
    echo "ERROR: Required environment variable '${var}' is not set."
    exit 1
  fi
done

# Configure Go environment
export GOPATH="${HOME}/go"
export GOFLAGS="-mod=vendor"
export CGO_ENABLED=0

echo "Go version: $(go version)"
echo "GOPATH: ${GOPATH}"

# Configure Docker BuildKit for improved build performance
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# Set the build version based on the branch or tag
if [[ "${BUILDKITE_TAG:-}" != "" ]]; then
  export BUILDKITE_BUILD_VERSION="${BUILDKITE_TAG}"
elif [[ "${BUILDKITE_BRANCH}" == "master" ]]; then
  export BUILDKITE_BUILD_VERSION="latest"
else
  # Sanitize branch name for use as a Docker tag
  SANITIZED_BRANCH=$(echo "${BUILDKITE_BRANCH}" | tr '/' '-' | tr '_' '-' | tr '[:upper:]' '[:lower:]')
  export BUILDKITE_BUILD_VERSION="${SANITIZED_BRANCH}-${BUILDKITE_BUILD_NUMBER}"
fi

echo "Build version: ${BUILDKITE_BUILD_VERSION}"

# Authenticate with Docker Hub if credentials are available
if [[ -n "${DOCKER_USERNAME:-}" && -n "${DOCKER_PASSWORD:-}" ]]; then
  echo '--- :docker: Authenticating with Docker Hub'
  echo "${DOCKER_PASSWORD}" | docker login --username "${DOCKER_USERNAME}" --password-stdin
fi

# Authenticate with GitHub Container Registry if credentials are available
if [[ -n "${GHCR_USERNAME:-}" && -n "${GHCR_PASSWORD:-}" ]]; then
  echo '--- :github: Authenticating with GitHub Container Registry'
  echo "${GHCR_PASSWORD}" | docker login ghcr.io --username "${GHCR_USERNAME}" --password-stdin
fi

# Set up Node.js environment if nvm is available
if command -v nvm &>/dev/null || [[ -f "${HOME}/.nvm/nvm.sh" ]]; then
  # shellcheck disable=SC1091
  source "${HOME}/.nvm/nvm.sh" || true
  if [[ -f ".nvmrc" ]]; then
    echo '--- :nodejs: Setting up Node.js via nvm'
    nvm install
    nvm use
    echo "Node version: $(node --version)"
    echo "NPM version: $(npm --version)"
  fi
fi

# Print summary of the environment
echo '--- :information_source: Build environment summary'
echo "Branch:       ${BUILDKITE_BRANCH}"
echo "Build Number: ${BUILDKITE_BUILD_NUMBER}"
echo "Pipeline:     ${BUILDKITE_PIPELINE_SLUG}"
echo "Version:      ${BUILDKITE_BUILD_VERSION}"
echo "Commit:       ${BUILDKITE_COMMIT:-unknown}"
